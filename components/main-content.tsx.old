"use client";

import { useState } from "react";
import { Card, CardContent } from "@/components/ui/card";
import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs";
import { ScrollArea } from "@/components/ui/scroll-area";
import { PodcastGrid } from "@/components/podcast-grid";
import { ChatInterface } from "@/components/chat-interface";
import { useAuth } from "@/hooks/use-auth";

export function MainContent() {
  const [activeTab, setActiveTab] = useState("discover");
  const { user, userProfile } = useAuth();

  return (
    <div className="flex-1 overflow-hidden">
      <Tabs 
        defaultValue="discover" 
        className="h-full flex flex-col"
        value={activeTab}
        onValueChange={setActiveTab}
      >
        <div className="border-b px-6 py-3">
          <TabsList className="grid w-[400px] grid-cols-2">
            <TabsTrigger value="discover">Discover</TabsTrigger>
            <TabsTrigger value="chat">Chat</TabsTrigger>
          </TabsList>
        </div>
        
        <ScrollArea className="flex-1 p-6">
          <TabsContent value="discover" className="mt-0 border-0 p-0">
            <div className="space-y-6">
              <div>
                <h2 className="text-2xl font-bold tracking-tight">Featured Podcasts</h2>
                <p className="text-muted-foreground">
                  Top picks and trending episodes for you
                </p>
              </div>
              <PodcastGrid />
              
              {user && userProfile?.subscription_type === 'premium' && (
                <>
                  <div className="mt-6">
                    <h2 className="text-2xl font-bold tracking-tight">Premium Content</h2>
                    <p className="text-muted-foreground">
                      Exclusive content for premium subscribers
                    </p>
                  </div>
                  <PodcastGrid filter="premium" />
                </>
              )}
              
              <div className="mt-6">
                <h2 className="text-2xl font-bold tracking-tight">Recently Played</h2>
                <p className="text-muted-foreground">
                  Pick up where you left off
                </p>
              </div>
              <PodcastGrid />
              
              <div className="mt-6">
                <h2 className="text-2xl font-bold tracking-tight">Popular Categories</h2>
                <p className="text-muted-foreground">
                  Explore podcasts by category
                </p>
              </div>
              <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
                {categories.map((category) => (
                  <Card key={category.name} className="overflow-hidden">
                    <CardContent className="p-0">
                      <div 
                        className="aspect-square relative flex items-center justify-center bg-gradient-to-br from-primary/20 to-primary/40"
                      >
                        <span className="font-bold text-lg">{category.name}</span>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            </div>
          </TabsContent>
          
          <TabsContent value="chat" className="mt-0 border-0 p-0 h-full">
            <ChatInterface />
          </TabsContent>
        </ScrollArea>
      </Tabs>
    </div>
  );
}

const categories = [
  { name: "News" },
  { name: "Technology" },
  { name: "Science" },
  { name: "Business" },
  { name: "Politics" },
  { name: "Health" },
  { name: "Education" },
  { name: "Entertainment" },
  { name: "Sports" },
  { name: "Arts" },
];